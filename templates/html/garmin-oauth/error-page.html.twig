{% autoescape false %}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>{{ appName }}</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width">
    <link rel="icon" type="image/x-icon" href="{{ relativeUrl('assets/images/logo.svg') }}">
    <link href="{{ relativeUrl(asset('css/dist/tailwind.min.css')) }}" rel="stylesheet"/>
</head>
<body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
{% include 'html/navigation/top-nav-bar.html.twig' %}
<section class="flex min-h-screen flex-col justify-center px-6 py-12 sm:px-12">
    <div class="mx-auto w-full max-w-xl p-6 bg-white border border-gray-200 rounded-lg shadow-xs">
        <h2 class="text-2xl font-bold tracking-tight">Garmin authorization failed</h2>
        <pre class="mt-6 overflow-hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 font-mono text-sm text-red-800 whitespace-pre-wrap">{{ error }}</pre>
        <a href="{{ path('garmin_oauth') }}" class="mt-6 inline-flex w-full items-center justify-center gap-2.5 rounded-xl bg-primary px-5 py-3 font-semibold text-white shadow-sm transition hover:brightness-95">Try again</a>
    </div>
</section>
</body>
</html>
{% endautoescape %}
