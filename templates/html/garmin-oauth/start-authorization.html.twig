{% autoescape false %}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>{{ appName }}</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width">
    <link rel="icon" type="image/x-icon" href="{{ relativeUrl('assets/images/logo.svg') }}">
    <link href="{{ relativeUrl(asset('css/dist/tailwind.min.css')) }}" rel="stylesheet"/>
</head>
<body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
{% include 'html/navigation/top-nav-bar.html.twig' %}
<section class="flex min-h-screen flex-col justify-center px-6 py-12 sm:px-12">
    <div class="mx-auto w-full max-w-xl p-6 bg-white border border-gray-200 rounded-lg shadow-xs">
        <h2 class="text-2xl font-bold tracking-tight">Connect your Garmin account</h2>
        {% if authorized %}
            <p class="mt-3 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">Garmin is already connected. New activities can be imported by the daemon.</p>
        {% endif %}
        {% if not configured %}
            <p class="mt-3 rounded-xl border border-yellow-200 bg-yellow-50 px-4 py-3 text-sm text-yellow-900">Set <code>GARMIN_CLIENT_ID</code> and <code>GARMIN_CLIENT_SECRET</code> before connecting Garmin.</p>
        {% else %}
            <p class="mt-1 text-sm text-gray-500">Authorize Garmin so Dreeve can import activities synced from Garmin Connect.</p>
            <a href="{{ path('garmin_oauth', {'start': 1}) }}" class="mt-6 inline-flex w-full items-center justify-center gap-2.5 rounded-xl bg-primary px-5 py-3 font-semibold text-white shadow-sm transition hover:brightness-95">Connect with Garmin</a>
        {% endif %}
    </div>
</section>
</body>
</html>
{% endautoescape %}
